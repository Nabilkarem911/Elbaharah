# ===== Dokploy Compose Environment =====
# Fill these in Dokploy's Environment Variables section

DB_HOST=your_dokploy_postgres_container_name
DB_PORT=5432
DB_NAME=elbharah
DB_USER=elbharah
DB_PASSWORD=your_strong_password_here

JWT_SECRET=change_this_to_random_long_string
JWT_EXPIRES_IN=24h
CORS_ORIGIN=*
